# Copy to server/.env (gitignored). Never commit real keys.

# ─── Blog Image Studio (local / non-production only) ───
# OpenCode Zen text model writes image prompts (no vision). Paste handoff into Grok Build to generate images.
# OPENCODE_API_KEY=
# Preferred model (falls back if unsupported). qwen3.5-plus is fast; thinking-heavy models can take 45–90s.
# Qwen 3.7 Plus/Max use the Go gateway (/zen/go/v1/messages); 3.5/3.6 use Zen (/zen/v1/messages).
# OPENCODE_MODEL=qwen3.5-plus
# OPENCODE_MODEL_FALLBACK=qwen3.6-plus
# OPENCODE_TIMEOUT_MS=45000
# Hard cap on concurrent OpenCode HTTP calls (1–3; default 3)
# OPENCODE_MAX_CONCURRENT=3
# Optional shared secret if you open studio from non-localhost (header x-blog-studio-token)
# BLOG_STUDIO_TOKEN=
# Force-disable even in development
# BLOG_STUDIO_ENABLED=false
#
# X Post Studio (local; source pack branding/x-ads-*.md) — http://127.0.0.1:3002/x-studio
# Shares BLOG_STUDIO_TOKEN if set, or X_POST_STUDIO_TOKEN=
# X_POST_STUDIO_ENABLED=false
#
# X API OAuth 1.0a (user context) — enables "Post to X" in the studio.
# App must be Read and write; regenerate Access Token after enabling write.
# Never commit real keys. Local / non-production only.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# Optional: schedule worker poll interval (ms, min 5000, default 15000)
# X_POST_SCHEDULE_TICK_MS=15000

# Resend transactional email (ready-to-seal notify)
RESEND_API_KEY=
# true once sending domain is verified in Resend
RESEND_ENABLED=true
# Must use a verified domain
RESEND_FROM=VeriLock <notify@verilock.online>
# Public site origin for deep links in emails (no trailing slash)
APP_PUBLIC_URL=https://verilock.online
# Same origin for Stripe success/cancel URLs (no trailing slash)
PUBLIC_APP_URL=https://verilock.online
# Show optional email opt-in in the create UI
EMAIL_NOTIFY_UI=true

# Support contact form (POST /api/support/contact) — delivered via Resend
# SUPPORT_TO_EMAIL=support@verilock.online
#
# Cloudflare Turnstile (recommended in production)
# Dashboard: https://dash.cloudflare.com/ → Turnstile → add site (verilock.online)
# TURNSTILE_SITE_KEY=0x4AAAA...
# TURNSTILE_SECRET_KEY=0x4AAAA...
# When secret is set, tokens are required (set TURNSTILE_REQUIRED=false to relax)
# TURNSTILE_REQUIRED=true
# Expose the same site key on the public features endpoint (or rely on TURNSTILE_SITE_KEY above)
# Client also accepts VITE_TURNSTILE_SITE_KEY as a build-time override if needed.

# ─── Credits ───
# CREDITS_ENABLED=true
# CREDITS_STRIPE_ENABLED=false
# CREDITS_STRIPE_MARKUP=2
# CREDITS_MAX_PER_CHECKOUT=20
# CREDITS_MAX_PER_NIM_TOPUP=50
# SERVICE_WALLET_PRIVATE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_STATEMENT_DESCRIPTOR_SUFFIX=VERILOCK

