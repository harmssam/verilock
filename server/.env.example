# Copy to server/.env (gitignored). Never commit real keys.

# Resend transactional email (ready-to-seal notify)
RESEND_API_KEY=
# true once sending domain is verified in Resend
RESEND_ENABLED=true
# Must use a verified domain
RESEND_FROM=VeriLock <notify@verilock.online>
# Public site origin for deep links in emails (no trailing slash)
APP_PUBLIC_URL=https://verilock.online
# Show optional email opt-in in the create UI
EMAIL_NOTIFY_UI=true
