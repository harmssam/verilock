# ─── Local development ───
NODE_ENV=development
PORT=3002
SKIP_CHAIN_VERIFY=true

# Frontend dev server proxies /api → server (leave empty in production monolith)
# VITE_API_URL=
# Hub/Pay app label is hardcoded as "VeriLock" in client/src/nimiq.ts

# ─── Production (Railway — VeriLock-Journey) ───
# NODE_ENV=production
# PORT is set automatically by Railway
# Comma-separated allowlist for product API. Note: POST /api/verify/hash is open-CORS
# (hash-only directory lookup for VeriLock Offline desktop + web companions).
# CORS_ORIGIN=https://verilock.online
# PUBLIC_APP_URL=https://verilock.online
# APP_PUBLIC_URL=https://verilock.online

# Persistent storage — attach a Railway volume mounted at /data
DATA_DIR=/data
# DATABASE_PATH=/data/verilock.db
# DOCS_DIR=/data/docs

# Nimiq JSON-RPC (mainnet)
NIMIQ_RPC_URL=https://rpc.nimiqwatch.com
NIM_MIN_CONFIRMATIONS=1

# Lock / credit top-up sink (full fee or N× fee for credits)
# VITE_ATTESTATION_RECIPIENT=NQ81 5N9J RGBJ MLJQ NBKE MQ1R D27T XS8P CVKA
# ATTESTATION_RECIPIENT=NQ815N9JRGBJMLJQNBKEMQ1RD27TXS8PCVKA

# ─── Credits ───
# Production requires CREDITS_ENABLED=true (dev defaults on)
# CREDITS_ENABLED=true
# CREDITS_STRIPE_ENABLED=false
# CREDITS_STRIPE_MARKUP=2
# CREDITS_MAX_PER_CHECKOUT=20
# CREDITS_MAX_PER_NIM_TOPUP=50
# SERVICE_WALLET_PRIVATE_KEY=   # 32-byte hex; posts credit-seal proofs (fund with dust NIM)
# STRIPE_SECRET_KEY=            # set when ready for card checkout
# STRIPE_WEBHOOK_SECRET=        # from Stripe CLI / Dashboard webhook endpoint
# STRIPE_STATEMENT_DESCRIPTOR_SUFFIX=VERILOCK  # card statement after account prefix (max 22). Empty = omit.

# Never set in production
# SKIP_CHAIN_VERIFY=true
