# ─── Local development ───
NODE_ENV=development
PORT=3002
SKIP_CHAIN_VERIFY=true

# Frontend dev server proxies /api → server (leave empty in production monolith)
# VITE_API_URL=
# Hub/Pay app label is hardcoded as "VeriLock" in client/src/nimiq.ts

# ─── Production (Railway) ───
# NODE_ENV=production
# PORT is set automatically by Railway
# CORS_ORIGIN=https://your-app.up.railway.app

# Persistent storage — attach a Railway volume mounted at /data
DATA_DIR=/data
# DATABASE_PATH=/data/verilock.db
# DOCS_DIR=/data/docs

# Nimiq JSON-RPC (mainnet)
NIMIQ_RPC_URL=https://rpc.nimiqwatch.com
NIM_MIN_CONFIRMATIONS=1

# Lock attestation sink (Hub sends 1 luna here per seal). Override to change recipient.
# VITE_ATTESTATION_RECIPIENT=NQ81 5N9J RGBJ MLJQ NBKE MQ1R D27T XS8P CVKA
# ATTESTATION_RECIPIENT=NQ81 5N9J RGBJ MLJQ NBKE MQ1R D27T XS8P CVKA

# Never set in production
# SKIP_CHAIN_VERIFY=true